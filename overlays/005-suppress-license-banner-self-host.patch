# Why: Documenso's `<AdminLicenseStatusBanner>` renders a destructive red banner
#      when the licence-server's derived status is UNAUTHORIZED, EXPIRED, or
#      PAST_DUE. For BizRethink's self-host the licence server returns
#      UNAUTHORIZED because overlay 001 added the BIZRETHINK tier whose flags
#      include EE-gated features (cfr21, embedAuthoringWhiteLabel,
#      authenticationPortal, etc.). The banner is purely cosmetic — none of the
#      actual EE feature checks block functionality on self-host (per the
#      paywall audit memory note: self-host needs no licence). The banner just
#      pollutes the admin panel with a red error that future operators may
#      mistake for a real outage.
#
#      Fix: replace the entire component body with `return null`. We will never
#      see PAST_DUE or EXPIRED either (no billing relationship with Documenso
#      Inc. exists), so suppressing them too is strictly correct, not a loss of
#      signal.
#
#      First attempt (rejected): added 'UNAUTHORIZED' to the early-return guard.
#      That broke `tsc` because the downstream code references
#      `licenseStatus === 'UNAUTHORIZED'` in the className conditional and the
#      ts-pattern match — TypeScript narrows the type after the guard, so
#      those references became "no overlap" errors. Build deployment failed at
#      typecheck step. See git log around 6f398bcd for the failed attempt.
#
# Why-not-additive: The banner is rendered unconditionally from
#      `apps/remix/app/root.tsx`. Suppressing it requires editing the component
#      body. There is no prop, env var, or feature flag exposed by upstream.
#
# Upstream-merge-fragility: LOW. The patched file is a fully replaced React
#      component with a stable export name + prop shape (we kept
#      `AdminLicenseStatusBannerProps` exported so the call site continues to
#      compile). Conflicts only if upstream renames the export or changes the
#      consuming call site (root.tsx). Both are easy to fix during weekly sync.
#
# Side note: we changed the prop type from `TCachedLicense | null` to `unknown`
#      to drop the upstream import — the prop is unused. This means if upstream
#      ever changes `TCachedLicense`, our component continues to compile (good
#      for merges); the trade-off is that callers passing the prop don't get
#      typechecked here, but the call site in root.tsx does its own typing.
#
# Audit note: pairs with the `[License] Derived Status: UNAUTHORIZED` log line
#      that appeared in container startup logs as soon as overlay 001 was
#      deployed (2026-04-30 11:39 UTC). The licence server flags BIZRETHINK's
#      EE flag set; this patch silences the visual indicator only. The log
#      line itself is harmless and intentionally left in place — it's useful
#      breadcrumb during upstream-sync triage if Documenso ever adds new
#      licence states.
#
# Status: APPLIED 2026-04-30 (after the first attempt failed typecheck —
#         this is the corrected version).

diff --git a/apps/remix/app/components/general/admin-license-status-banner.tsx b/apps/remix/app/components/general/admin-license-status-banner.tsx
--- a/apps/remix/app/components/general/admin-license-status-banner.tsx
+++ b/apps/remix/app/components/general/admin-license-status-banner.tsx
@@ -1,87 +1,15 @@
-import { Trans } from '@lingui/react/macro';
-import { AlertTriangleIcon, KeyRoundIcon } from 'lucide-react';
-import { Link } from 'react-router';
-import { match } from 'ts-pattern';
